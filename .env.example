# 搜索关键词
KEYWORD=Java后端

# 城市 code（见 config.yaml）
CITY=101010100

# 最多抓取列表页数
MAX_PAGES=3

# 请求间隔（毫秒），实际会在 [DELAY_MS, DELAY_MS*2] 随机
DELAY_MS=2000

# 输出目录
DATA_DIR=data

# 登录态文件
STORAGE_STATE_PATH=auth/storage_state.json

# 浏览器有头模式（login 建议 true）
HEADLESS=false

# RAGForge 推送配置（可选，留空则只输出到本地 JSONL）
RAGFORGE_URL=http://localhost:8080
RAGFORGE_API_KEY=your-api-key-here
RAGFORGE_ENABLED=false

# 代理（云端部署时填入，本机留空）
HTTP_PROXY=

# RAGForge 知识库 ID（在 RAGForge 管理台查看）
RAGFORGE_JD_KB_ID=1
RAGFORGE_INTERVIEW_KB_ID=2
RAGFORGE_SALARY_KB_ID=3

# GitHub API Token（可选，填写后 API 限额从 60次/h 提升至 5000次/h）
GITHUB_TOKEN=

# ── 云端部署说明 ──────────────────────────────────────────
# 1. 本地登录（需要有屏幕）：
#      python cli.py login
#    登录成功后会生成 auth/storage_state.json
#
# 2. 上传 cookies 到云服务器：
#      scp auth/storage_state.json user@your-server:/app/auth/
#
# 3. 云服务器运行（无需 GUI）：
#      HEADLESS=true python cli.py scrape
#    或：
#      docker-compose up boss-scraper
#
# cookies 有效期约 7-14 天，到期后重复步骤 1-2
